rules_version = '2';

// Firestore is fully locked to direct client access. ALL reads and writes to
// wildlife_detections go through our authenticated Next.js server routes, which
// use the Admin SDK (and bypass these rules). Nothing reaches Firestore from a
// browser or a camera directly.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
