# ============================================================================
# Copy this file to ".env.local" and fill in your values. .env.local is
# gitignored and must NEVER be committed.
#
# Filled-in defaults below match the louielabs-animal-cams project as verified
# on 2026-06-26. Double-check them against your console.
# ============================================================================

# ---- Google Cloud / Firebase (SERVER side, KEYLESS) ------------------------
# We use Application Default Credentials (ADC). There are NO JSON key files.
# Log in once with impersonation:
#   gcloud auth application-default login \
#     --impersonate-service-account=cloud-backend@louielabs-animal-cams.iam.gserviceaccount.com
GCP_PROJECT_ID=louielabs-animal-cams
GCLOUD_STORAGE_BUCKET=wildlife-camera-telemetry

# Realtime Database (live device state + commands). NOTE: Realtime Database is
# NOT offered in us-west1 -- create it in us-central1. The default instance URL
# looks like this (confirm in Firebase console after you create it):
FIREBASE_DATABASE_URL=https://louielabs-animal-cams-default-rtdb.firebaseio.com

# Firestore (wildlife_detections). This project uses a NAMED database, not the
# "(default)" one, so we set its id explicitly. It lives in us-west1.
FIRESTORE_DATABASE_ID=wildlife-camera-telemetry-db

# Shared key for the server-to-server Gemini detection pipeline (POST
# /api/detections). Camera boards NO LONGER use this -- each board authenticates
# with its own per-device secret instead (stored under /pre_shared_keys in RTDB).
# Make this a long random string (e.g. `openssl rand -hex 24`).
CAMERA_API_KEY=change-me-to-a-long-random-string

# Environment tag for all created artifacts. Local dev = "dev" (images go under
# dev/ in the bucket, detections carry env:"dev"); Cloud Run sets this to "prod".
# Purge dev data anytime with `npm run clean:dev`. (Missing -> treated as "prod"
# to fail safe.)
APP_ENV=dev

# ---- Firebase Web (CLIENT side) --------------------------------------------
# These NEXT_PUBLIC_* values are NOT secrets. Firebase web config is meant to be
# public; real protection lives in the server routes + database rules.
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=louielabs-animal-cams.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=louielabs-animal-cams
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://louielabs-animal-cams-default-rtdb.firebaseio.com
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=louielabs.com
