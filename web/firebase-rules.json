{
  "rules": {
    ".read": false,
    ".write": false,

    "devices": {
      "$device_id": {
        "state": {
          ".write": "newData.child('secret').val() === root.child('pre_shared_keys').child($device_id).val()"
        },
        "command": {
          ".read": true
        }
      }
    },

    "pre_shared_keys": {
      ".read": false,
      ".write": false
    },

    "device_meta": {
      ".read": false,
      ".write": false
    }
  }
}
