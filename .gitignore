# Credentials / secrets — never commit
secrets.h
**/secrets.h
# (the committed template secrets.example.h is intentionally NOT ignored)

# Auto-generated per build by the prebuild hook in
# firmware/heltec-core-overrides/platform.local.txt (writes the current git
# short SHA). cloud_telemetry_node/version.h picks it up via __has_include.
**/build_version.h

# Arduino build output
build/
*.bin
*.elf
*.hex
*.map
# ...but the dashboard's distributable firmware image (secret-free; rebuilt by
# scripts/build-firmware-image.sh) IS served and committed.
!web/public/firmware/*.bin

# Local scratch / temp
tmp/

# PlatformIO local build caches and compiled binaries
.pio/
.pioenvs/

# Local VS Code workspace settings (per Gemini for sharing configs)
.vscode/*
!.vscode/extensions.json

# OS-specific hidden garbage files
**/.DS_Store
**/Thumbs.db

# Firebase emulator runtime artifacts (created by `npm run test:rules`)
**/firebase-debug.log
**/firestore-debug.log
**/database-debug.log
**/firebase-debug.*.log
**/firestore-debug.*.log
**/database-debug.*.log
**/.firebase/
**/firestore_export/
**/database_export/
**/ui-debug.log